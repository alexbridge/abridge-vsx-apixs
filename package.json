{
  "name": "apixs",
  "displayName": "APIxs",
  "description": "High-performance, git-friendly, API client with familiar pm-scripting support (xs = extra scripting)",
  "version": "1.0.4",
  "publisher": "abridge",
  "author": "abridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexbridge/abridge-vsx-apixs.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icons/logo.png",
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "postman",
    "bruno",
    "http-client",
    "rest-client",
    "http client",
    "rest client",
    "http",
    "client",
    "vscode-extension",
    "runner"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "build:webview": "node esbuild.webview.js",
    "build:css": "npx @tailwindcss/cli -i webview/styles.css -o dist/tailwind.css --minify",
    "build:all": "npm run build && npm run build:webview && npm run build:css",
    "build:production": "node esbuild.js --production && node esbuild.webview.js --production && npm run build:css",
    "package": "yes | npx @vscode/vsce package --no-dependencies",
    "watch": "node esbuild.js --watch",
    "lint": "npm run format:check && tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "contributes": {
    "commands": [
      {
        "command": "apixs.open",
        "title": "Open Apixs",
        "category": "Apixs",
        "icon": "$(window)"
      },
      {
        "command": "apixs.import",
        "title": "Import Collection/Environment",
        "category": "Apixs",
        "icon": "$(cloud-download)"
      },
      {
        "command": "apixs.newCollection",
        "title": "New Collection",
        "category": "Apixs",
        "icon": "$(add)"
      },
      {
        "command": "apixs.refreshCollections",
        "title": "Refresh",
        "category": "Apixs",
        "icon": "$(refresh)"
      },
      {
        "command": "apixs.deleteCollection",
        "title": "Delete Collection",
        "category": "Apixs",
        "icon": "$(trash)"
      },
      {
        "command": "apixs.duplicateCollection",
        "title": "Duplicate Collection",
        "category": "Apixs",
        "icon": "$(copy)"
      },
      {
        "command": "apixs.renameCollection",
        "title": "Rename Collection",
        "category": "Apixs",
        "icon": "$(edit)"
      },
      {
        "command": "apixs.addFolder",
        "title": "New Folder",
        "category": "Apixs",
        "icon": "$(new-folder)"
      },
      {
        "command": "apixs.renameFolder",
        "title": "Rename Folder",
        "category": "Apixs",
        "icon": "$(edit)"
      },
      {
        "command": "apixs.deleteFolder",
        "title": "Delete Folder",
        "category": "Apixs",
        "icon": "$(trash)"
      },
      {
        "command": "apixs.duplicateFolder",
        "title": "Duplicate Folder",
        "category": "Apixs",
        "icon": "$(copy)"
      },
      {
        "command": "apixs.openSseViewer",
        "title": "SSE Viewer",
        "category": "Apixs",
        "icon": "$(radio-tower)"
      },
      {
        "command": "apixs.addRequest",
        "title": "New Request",
        "category": "Apixs",
        "icon": "$(add)"
      },
      {
        "command": "apixs.renameRequest",
        "title": "Rename Request",
        "category": "Apixs",
        "icon": "$(edit)"
      },
      {
        "command": "apixs.deleteRequest",
        "title": "Delete Request",
        "category": "Apixs",
        "icon": "$(trash)"
      },
      {
        "command": "apixs.duplicateRequest",
        "title": "Duplicate Request",
        "category": "Apixs",
        "icon": "$(copy)"
      },
      {
        "command": "apixs.moveUp",
        "title": "Move Up",
        "category": "Apixs",
        "icon": "$(arrow-up)"
      },
      {
        "command": "apixs.moveDown",
        "title": "Move Down",
        "category": "Apixs",
        "icon": "$(arrow-down)"
      },
      {
        "command": "apixs.send",
        "title": "Send Request",
        "category": "Apixs"
      },
      {
        "command": "apixs.save",
        "title": "Save Request",
        "category": "Apixs"
      },
      {
        "command": "apixs.switchEnvironment",
        "title": "Switch Environment",
        "category": "Apixs"
      },
      {
        "command": "apixs.runFolder",
        "title": "Run Folder",
        "category": "Apixs",
        "icon": "$(play)"
      },
      {
        "command": "apixs.openCollectionSettings",
        "title": "Collection Settings",
        "category": "Apixs",
        "icon": "$(gear)"
      },
      {
        "command": "apixs.openFolderSettings",
        "title": "Folder Settings",
        "category": "Apixs",
        "icon": "$(gear)"
      },
      {
        "command": "apixs.newEnvironment",
        "title": "New Environment",
        "category": "Apixs",
        "icon": "$(add)"
      },
      {
        "command": "apixs.openEnvironment",
        "title": "Edit Environment",
        "category": "Apixs",
        "icon": "$(edit)"
      },
      {
        "command": "apixs.openGlobals",
        "title": "Edit Globals",
        "category": "Apixs",
        "icon": "$(edit)"
      },
      {
        "command": "apixs.activateEnvironment",
        "title": "Set Active",
        "category": "Apixs",
        "icon": "$(check)"
      },
      {
        "command": "apixs.renameEnvironment",
        "title": "Rename Environment",
        "category": "Apixs",
        "icon": "$(edit)"
      },
      {
        "command": "apixs.duplicateEnvironment",
        "title": "Duplicate Environment",
        "category": "Apixs",
        "icon": "$(copy)"
      },
      {
        "command": "apixs.deleteEnvironment",
        "title": "Delete Environment",
        "category": "Apixs",
        "icon": "$(trash)"
      },
      {
        "command": "apixs.refreshEnvironments",
        "title": "Refresh Environments",
        "category": "Apixs",
        "icon": "$(refresh)"
      },
      {
        "command": "apixs.findRequest",
        "title": "Find Request",
        "category": "Apixs",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apixs.findRequest",
          "when": "view == apixs.collections",
          "group": "navigation"
        },
        {
          "command": "apixs.newCollection",
          "when": "view == apixs.collections",
          "group": "navigation"
        },
        {
          "command": "apixs.import",
          "when": "view == apixs.collections",
          "group": "navigation"
        },
        {
          "command": "apixs.refreshCollections",
          "when": "view == apixs.collections",
          "group": "navigation"
        },
        {
          "command": "apixs.newEnvironment",
          "when": "view == apixs.environments",
          "group": "navigation"
        },
        {
          "command": "apixs.refreshEnvironments",
          "when": "view == apixs.environments",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "apixs.openCollectionSettings",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "inline@1"
        },
        {
          "command": "apixs.runFolder",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "inline@2"
        },
        {
          "command": "apixs.addFolder",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "inline@3"
        },
        {
          "command": "apixs.addRequest",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "inline@4"
        },
        {
          "command": "apixs.addFolder",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "1_add@1"
        },
        {
          "command": "apixs.addRequest",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "1_add@2"
        },
        {
          "command": "apixs.renameCollection",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "2_edit@1"
        },
        {
          "command": "apixs.duplicateCollection",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "2_edit@2"
        },
        {
          "command": "apixs.moveUp",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "2_edit@3"
        },
        {
          "command": "apixs.moveDown",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "2_edit@4"
        },
        {
          "command": "apixs.deleteCollection",
          "when": "view == apixs.collections && viewItem == collection",
          "group": "3_delete@1"
        },
        {
          "command": "apixs.openFolderSettings",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "inline@1"
        },
        {
          "command": "apixs.runFolder",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "inline@2"
        },
        {
          "command": "apixs.addFolder",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "inline@3"
        },
        {
          "command": "apixs.addRequest",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "inline@4"
        },
        {
          "command": "apixs.addFolder",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "1_add@1"
        },
        {
          "command": "apixs.addRequest",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "1_add@2"
        },
        {
          "command": "apixs.renameFolder",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "2_edit@1"
        },
        {
          "command": "apixs.duplicateFolder",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "2_edit@2"
        },
        {
          "command": "apixs.moveUp",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "2_edit@3"
        },
        {
          "command": "apixs.moveDown",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "2_edit@4"
        },
        {
          "command": "apixs.deleteFolder",
          "when": "view == apixs.collections && viewItem == folder",
          "group": "3_delete@1"
        },
        {
          "command": "apixs.renameRequest",
          "when": "view == apixs.collections && viewItem == request",
          "group": "2_edit@1"
        },
        {
          "command": "apixs.duplicateRequest",
          "when": "view == apixs.collections && viewItem == request",
          "group": "2_edit@2"
        },
        {
          "command": "apixs.moveUp",
          "when": "view == apixs.collections && viewItem == request",
          "group": "2_edit@3"
        },
        {
          "command": "apixs.moveDown",
          "when": "view == apixs.collections && viewItem == request",
          "group": "2_edit@4"
        },
        {
          "command": "apixs.deleteRequest",
          "when": "view == apixs.collections && viewItem == request",
          "group": "3_delete@1"
        },
        {
          "command": "apixs.openGlobals",
          "when": "view == apixs.environments && viewItem == globals",
          "group": "inline@1"
        },
        {
          "command": "apixs.activateEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "inline@1"
        },
        {
          "command": "apixs.openEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "inline@2"
        },
        {
          "command": "apixs.activateEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "1_actions@1"
        },
        {
          "command": "apixs.openEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "1_actions@2"
        },
        {
          "command": "apixs.renameEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "2_edit@1"
        },
        {
          "command": "apixs.duplicateEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "2_edit@2"
        },
        {
          "command": "apixs.deleteEnvironment",
          "when": "view == apixs.environments && viewItem =~ /^environment/",
          "group": "3_delete@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apixs",
          "title": "Apixs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "apixs": [
        {
          "id": "apixs.collections",
          "name": "Collections"
        },
        {
          "id": "apixs.environments",
          "name": "Environments"
        }
      ]
    },
    "configuration": {
      "title": "Apixs",
      "properties": {
        "apixs.defaultTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Default request timeout in milliseconds"
        },
        "apixs.sslVerification": {
          "type": "boolean",
          "default": true,
          "description": "Enable SSL certificate verification"
        },
        "apixs.proxy": {
          "type": "string",
          "default": "",
          "description": "HTTP proxy URL (e.g., http://proxy:8080)"
        }
      }
    },
    "keybindings": [
      {
        "command": "apixs.send",
        "key": "ctrl+enter",
        "when": "apixs.panelFocused"
      },
      {
        "command": "apixs.save",
        "key": "ctrl+s",
        "when": "apixs.panelFocused"
      },
      {
        "command": "apixs.switchEnvironment",
        "key": "ctrl+e",
        "when": "apixs.panelFocused"
      }
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.1",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "got": "^14.0.0",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "monaco-editor": "^0.53.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  }
}